# ArgueX Backend .env example
# Copy this file to .env and fill the values before running the server

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string (required in production)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/arguex?retryWrites=true&w=majority

# JWT secret used to sign tokens
JWT_SECRET=change_this_to_a_strong_secret

# Optional: AI API key (if using AI features)
AI_API_KEY=

# Allow socket connections without JWT (ONLY for local dev/testing)
# Set to true only in development: ALLOW_SOCKET_NOAUTH=true
ALLOW_SOCKET_NOAUTH=false
